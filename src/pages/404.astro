---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Pagina non trovata" description="La pagina richiesta non è stata trovata." canonicalPath="/404">
  <section class="flex min-h-[50vh] flex-col items-center justify-center px-4 py-16 text-center">
    <h1 class="text-6xl font-bold text-primary-dark">404</h1>
    <p class="mt-4 text-xl text-muted">Pagina non trovata</p>
    <a href="/" class="btn btn-primary mt-8">Torna alla Home</a>
  </section>
</BaseLayout>
