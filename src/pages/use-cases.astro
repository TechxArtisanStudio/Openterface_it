---
import BaseLayout from '../layouts/BaseLayout.astro';
import DocLinkBanner from '../components/DocLinkBanner.astro';
import { legacyPath } from '../config/site';
---

<BaseLayout
  title="Casi d'Uso"
  description="Casi d'uso reali per i prodotti KVM-over-USB Openterface."
  canonicalPath="/use-cases/"
>
  <DocLinkBanner />
  <section class="py-16">
    <div class="mx-auto max-w-3xl px-4">
      <h1 class="text-4xl font-bold">Casi d'Uso</h1>
      <p class="mt-4 text-lg text-muted">
        Gli strumenti Openterface danno il meglio di sé ogni volta che hai bisogno di controllare un computer headless o difficile da raggiungere senza un
        monitor e una tastiera dedicati.
      </p>
      <ul class="mt-8 space-y-4">
        {
          [
            'Ispezioni in data center e colocation',
            'Amministrazione di homelab e NAS',
            'Avvio di dispositivi embedded e SBC',
            'Manutenzione di chioschi e segnaletica digitale',
            'IT sul campo e attività di consulenza',
          ].map((item) => (
            <li class="card">{item}</li>
          ))
        }
      </ul>
      <a href={legacyPath('/use-cases/')} class="btn btn-secondary mt-8" target="_blank" rel="noopener">
        Vedi la galleria completa dei casi d'uso →
      </a>
    </div>
  </section>
</BaseLayout>
