---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DocLinkBanner from '../../components/DocLinkBanner.astro';
import { legacyPath } from '../../config/site';
---

<BaseLayout
  title="Informazioni su Openterface"
  description="Scopri Openterface — soluzioni KVM-over-USB open source costruite da TechxArtisan."
  canonicalPath="/about/"
>
  <DocLinkBanner />
  <section class="py-16">
    <div class="mx-auto max-w-3xl px-4">
      <h1 class="text-4xl font-bold">Informazioni su Openterface</h1>
      <p class="mt-6 text-lg leading-relaxed text-muted">
        Openterface realizza strumenti KVM-over-USB ultra-compatti e open source per professionisti IT, sviluppatori e maker.
        Dal Mini-KVM finanziato tramite crowdfunding al KVM-GO a misura di portachiavi e alla serie KeyMod programmabile, la nostra missione è
        semplificare il controllo dei computer headless senza attrezzature ingombranti o reti complesse.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href={legacyPath('/about/about-us/')} class="btn btn-secondary" target="_blank" rel="noopener">
          Chi Siamo Completo →
        </a>
        <a href={legacyPath('/about/compliance/')} class="btn btn-secondary" target="_blank" rel="noopener">
          Conformità →
        </a>
        <a href={legacyPath('/about/community/')} class="btn btn-secondary" target="_blank" rel="noopener">
          Community →
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
