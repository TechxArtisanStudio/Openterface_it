---
import BaseLayout from '../layouts/BaseLayout.astro';
import DocLinkBanner from '../components/DocLinkBanner.astro';
import { legacyPath } from '../config/site';
---

<BaseLayout
  title="Video"
  description="Demo dei prodotti Openterface, tutorial e recensioni su YouTube."
  canonicalPath="/videos/"
>
  <DocLinkBanner message="La griglia video completa e filtrabile di YouTube si trova sul sito legacy finché non porteremo la pipeline video." />
  <section class="py-16">
    <div class="mx-auto max-w-3xl px-4 text-center">
      <h1 class="text-4xl font-bold">Video</h1>
      <p class="mt-4 text-lg text-muted">
        Guarda le demo dei prodotti, le guide alla configurazione e le recensioni della community per i prodotti Openterface KVM e KeyMod.
      </p>
      <a href={legacyPath('/videos/')} class="btn btn-primary mt-8" target="_blank" rel="noopener">
        Sfoglia tutti i video →
      </a>
    </div>
  </section>
</BaseLayout>
